# PostgreSQL
POSTGRES_USER=nl2vis
POSTGRES_PASSWORD=nl2vis
POSTGRES_DB=nl2vis
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://your_user:your_password@localhost:5432/your_database

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Sandbox executor
SANDBOX_PORT=5001
SANDBOX_EXECUTOR_TIMEOUT=30
SANDBOX_MAX_OUTPUT=65536

# 应用配置(开发环境改为true)
DEBUG=false

# CORS 配置
# 多个域名用逗号分隔，不要有空格
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT
JWT_SECRET=your-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
