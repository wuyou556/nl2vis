# PostgreSQL
POSTGRES_USER=nl2vis
POSTGRES_PASSWORD=nl2vis
POSTGRES_DB=nl2vis
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://your_user:your_password@localhost:5432/your_database

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Sandbox executor
SANDBOX_PORT=5001
SANDBOX_EXECUTOR_TIMEOUT=30
SANDBOX_MAX_OUTPUT=65536

# 应用配置(开发环境改为true)
DEBUG=false

# CORS 配置
# 多个域名用逗号分隔，不要有空格
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT
JWT_SECRET=your-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM 配置（Agent 使用）
# 支持所有 OpenAI 兼容的 API：DeepSeek / 通义千问 / 智谱 / OpenAI 等
LLM_MODEL_NAME=deepseek-chat
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# Agent 行为
AGENT_MAX_ITERATIONS=10
AGENT_TOOL_TIMEOUT=30
AGENT_VERBOSE=true
SANDBOX_URL=http://localhost:5001

# Memory 配置
MEMORY_MAX_TOKENS=4000
MEMORY_MAX_MESSAGES=200
